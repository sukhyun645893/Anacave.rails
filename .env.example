RAILS_ENV=production
APP_HOST=example.com
RAILS_MASTER_KEY=replace_with_config_master_key
SECRET_KEY_BASE=replace_with_bin_rails_secret

# PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/community_production

# Local PostgreSQL development
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=community_development
POSTGRES_TEST_DB=community_test

# Upload storage: local, amazon, or cloudflare_r2
ACTIVE_STORAGE_SERVICE=cloudflare_r2

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_BUCKET=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# HTTPS behind proxy/load balancer
RAILS_ASSUME_SSL=true
RAILS_FORCE_SSL=true
