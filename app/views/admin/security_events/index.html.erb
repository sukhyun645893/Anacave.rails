<section class="section-heading">
  <div>
    <h1>보안 기록</h1>
    <p>최근 글/댓글 작성 시점의 운영 방어용 접속 기록입니다. 일반 이용자에게는 공개되지 않습니다.</p>
  </div>
  <%= link_to "신고 관리", admin_root_path, class: "button" %>
</section>

<div class="admin-list">
  <% if @security_events.any? %>
    <% @security_events.each do |event| %>
      <article class="admin-card">
        <div>
          <h2><%= event.record_label %></h2>
          <p class="meta">
            <%= event.action %> ·
            <%= event.user&.display_name || "알 수 없음" %> ·
            <%= time_ago_in_words(event.created_at) %> 전
          </p>
          <p>IP: <%= event.ip_address %></p>
          <p class="meta">IP 해시: <%= event.ip_address_hash %></p>
          <p class="meta">브라우저: <%= event.user_agent.presence || "없음" %></p>
          <p class="meta">보관 만료: <%= l(event.retained_until, format: :long) %></p>
        </div>
      </article>
    <% end %>
  <% else %>
    <p class="empty">아직 보안 기록이 없습니다.</p>
  <% end %>
</div>
