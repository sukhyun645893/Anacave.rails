<%= render @post %>

<section class="vote-panel">
  <div class="vote-score vote-score-split">
    <div>
      <strong><%= @post.upvotes_count %></strong>
      <span>추천</span>
    </div>
    <div>
      <strong><%= @post.downvotes_count %></strong>
      <span>비추천</span>
    </div>
  </div>

  <div class="vote-actions">
    <%= button_to "추천", post_post_votes_path(@post, value: "up"), method: :post, class: "button primary", disabled: @post.upvoted_today_by?(Current.user) %>
    <%= button_to "비추천", post_post_votes_path(@post, value: "down"), method: :post, class: "button", disabled: @post.downvoted_today_by?(Current.user) %>
  </div>

  <% if authenticated? %>
    <p class="meta">
      추천과 비추천은 각각 하루에 한 번씩 누를 수 있습니다.
      <% if @post.upvoted_today_by?(Current.user) %> 오늘 추천 완료. <% end %>
      <% if @post.downvoted_today_by?(Current.user) %> 오늘 비추천 완료. <% end %>
    </p>
  <% else %>
    <p class="meta"><%= link_to "로그인", new_session_path %>하면 추천/비추천할 수 있습니다.</p>
  <% end %>
</section>

<div class="actions">
  <%= link_to "챕터로", chapter_path(@post.chapter), class: "button" %>

  <% if authenticated? %>
    <%= button_to "게시글 신고", reports_path, method: :post, class: "button", params: { report: { reportable_type: "Post", reportable_id: @post.id, reason: "other" } } %>
  <% end %>

  <% if @post.user == Current.user %>
    <%= link_to "수정", edit_post_path(@post), class: "button" %>
    <%= button_to "삭제", @post, method: :delete, class: "button danger" %>
  <% end %>

  <% if Current.user&.admin? %>
    <%= button_to "관리자 삭제", admin_post_path(@post), method: :delete, class: "button danger" %>
    <% unless @post.user.blocked? %>
      <%= button_to "작성자 차단", block_admin_user_path(@post.user), method: :patch, class: "button danger" %>
    <% else %>
      <%= button_to "작성자 차단 해제", unblock_admin_user_path(@post.user), method: :patch, class: "button" %>
    <% end %>
  <% end %>
</div>

<section class="comments">
  <h2>댓글 <%= @post.comments.size %></h2>

  <% if authenticated? %>
    <%= form_with model: [@post, Comment.new], class: "comment-form", data: { controller: "comment-anacon" } do |form| %>
      <%= form.label :body, "댓글" %>
      <%= form.text_area :body, rows: 4, placeholder: "생각을 남겨보세요.", data: { comment_anacon_target: "input" } %>
      <%= render "anacons/picker", anacons: Current.user.downloaded_anacons.approved.includes(images_attachments: :blob).order("user_anacons.created_at DESC"), mode: :comment %>
      <%= form.submit "등록", class: "button primary" %>
    <% end %>
  <% else %>
    <p><%= link_to "로그인", new_session_path %>하면 댓글을 쓸 수 있습니다.</p>
  <% end %>

  <div class="comment-list">
    <% @post.comments.where(parent_id: nil).includes(user: { avatar_attachment: :blob }).order(created_at: :asc).each do |comment| %>
      <%= render "comments/thread_comment", comment: comment, post: @post, depth: 0 %>
    <% end %>
  </div>
</section>
